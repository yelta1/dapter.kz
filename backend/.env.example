# Параметры сервера
PORT=8080
ENV=development # development, production

# Подключение к базе данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dapter_db
DB_SSLMODE=disable

# Безопасность
# ENCRYPTION_KEY должен быть 32-байтовым ключом в hex-формате для AES-256-GCM.
# Пример генерации: openssl rand -hex 32
ENCRYPTION_KEY=6368616e676520746869732070617373776f726420746f203332206279746573
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# WhatsApp Шлюз Green API (Для отладочной заглушки укажите mock-...)
GREEN_API_URL=https://api.green-api.com
GREEN_API_ID_INSTANCE=mock-id-instance
GREEN_API_TOKEN_INSTANCE=mock-token-instance
